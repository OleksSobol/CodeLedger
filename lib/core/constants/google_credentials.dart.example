// Stub file for CI builds. The real google_credentials.dart is gitignored
// and contains the OAuth client ID for Drive backup. CI fills in this stub
// so the app compiles; Drive sign-in will fail at runtime with this empty
// value, which is fine for nightly preview APKs.
//
// To run with working Drive backup, copy this file to google_credentials.dart
// and set googleServerClientId to your Google OAuth web client ID.
const String googleServerClientId = '';
